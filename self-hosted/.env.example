# Database
DB_NAME=timesheet
DB_USER=timesheet
DB_PASSWORD=change-me-strong-password

# Application
SECRET_KEY=change-me-64-char-random-string
ENCRYPTION_KEY=change-me-32-byte-hex-string

# License
LICENSE_KEY=paste-your-license-jwt-here
LICENSE_PUBLIC_KEY_PEM=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----
LICENSE_SERVER_HASH_SALT=change-me-random-salt
LICENSE_API_URL=https://licenses.yourdomain.com

# Images
IMAGE_REGISTRY=ghcr.io/yourorg/timesheet-api
IMAGE_TAG=latest

# Ports
API_PORT=8000
FRONTEND_PORT=3000

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# Browser-facing API base URL
API_BASE_URL=http://your-server-ip:8000
