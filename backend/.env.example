# Database
DATABASE_URL=postgresql+asyncpg://timesheet_user:timesheet_pass@localhost:5432/timesheet_db

# JWT — REQUIRED: generate a strong random key
# python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS — set to your frontend domain(s) in production
CORS_ORIGINS=["http://localhost:5173","http://localhost:5174"]

# App — set DEBUG=false in production
DEBUG=true
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# Ingestion platform integration
INGESTION_PLATFORM_URL=http://localhost:3001
INGESTION_SERVICE_TOKEN=

# Encryption — REQUIRED for email ingestion
# python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=

# File storage
STORAGE_PATH=./uploads
STORAGE_PROVIDER=local
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# OpenAI — required for LLM extraction and NL time entry features
OPENAI_API_KEY=

# Google OAuth2 — required for Gmail mailbox connections
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/oauth/callback/google

# Microsoft OAuth2 — required for Outlook mailbox connections
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=http://localhost:8000/auth/oauth/callback/microsoft

# Redis — required for background job processing
REDIS_URL=redis://localhost:6379

# Frontend URL — used for email verification links
FRONTEND_BASE_URL=http://localhost:5174

# SMTP — outbound email notifications (optional)
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USERNAME=apikey
# SMTP_PASSWORD=
# SMTP_FROM_ADDRESS=no-reply@acufy.ai
# SMTP_FROM_NAME=Acufy Platform
# SMTP_USE_TLS=true

# ── Worker / Email Fetch Schedule ──────────────────────────────
# Cron tick minutes (comma-separated). Controls how often the worker
# checks for scheduled tasks. Default: every 15 min.
WORKER_CRON_MINUTES=0,5,10,15,20,25,30,35,40,45,50,55

# arq job settings
WORKER_JOB_TIMEOUT=300
WORKER_MAX_TRIES=3
WORKER_KEEP_RESULT=86400

# Default email auto-fetch schedule (per-tenant settings override these).
# Interval between fetches in minutes.
EMAIL_FETCH_INTERVAL_MINUTES=60
# Days to auto-fetch (comma-separated).
EMAIL_FETCH_DAYS=mon,tue,wed,thu,fri
# Time window for auto-fetch (HH:MM format).
EMAIL_FETCH_START_TIME=00:00
EMAIL_FETCH_END_TIME=23:59
# On first fetch (no cursor), only go back this many days.
EMAIL_FETCH_INITIAL_DAYS=30
