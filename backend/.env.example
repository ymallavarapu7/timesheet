# Database
DATABASE_URL=postgresql+asyncpg://timesheet_user:timesheet_pass@localhost:5432/timesheet_db

# JWT — REQUIRED: generate a strong random key
# python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS — set to your frontend domain(s) in production
CORS_ORIGINS=["http://localhost:5173","http://localhost:5174"]

# App — set DEBUG=false in production
DEBUG=true
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# Ingestion platform integration
INGESTION_PLATFORM_URL=http://localhost:3001
INGESTION_SERVICE_TOKEN=

# Encryption — REQUIRED for email ingestion
# python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=

# File storage
STORAGE_PATH=./uploads
STORAGE_PROVIDER=local
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# OpenAI — required for LLM extraction features
OPENAI_API_KEY=

# Google OAuth2 — required for Gmail mailbox connections
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/oauth/callback/google

# Microsoft OAuth2 — required for Outlook mailbox connections
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=http://localhost:8000/auth/oauth/callback/microsoft

# Redis — required for background job processing
REDIS_URL=redis://localhost:6379
